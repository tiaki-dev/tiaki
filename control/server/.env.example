# Database
DATABASE_URL=postgresql://tiaki:tiaki@localhost:5432/tiaki

# Server
PORT=3001
NODE_ENV=development

# Auth — shared secret for the admin UI and agent registration
# Generate with: openssl rand -hex 32
ADMIN_TOKEN=change-me-to-a-random-secret

# SMTP (optional, for email notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=tiaki@example.com

# Scan schedule (cron syntax)
SCAN_INTERVAL=0 */6 * * *

# LLM Integration (optional, for release notes summarization)
ANTHROPIC_API_KEY=your-anthropic-api-key

# GitHub Integration (optional, for fetching release notes with higher rate limits)
GITHUB_TOKEN=your-github-token
