FROM golang:1.23-alpine AS builder
WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o tiaki-agent ./cmd/docker

FROM ghcr.io/aquasecurity/trivy:latest AS trivy-bin

FROM alpine:3.23
RUN apk upgrade --no-cache && apk add --no-cache ca-certificates
COPY --from=builder /build/tiaki-agent /tiaki-agent
COPY --from=trivy-bin /usr/local/bin/trivy /usr/local/bin/trivy
ENTRYPOINT ["/tiaki-agent"]
